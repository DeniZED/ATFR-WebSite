# ── Discord ──────────────────────────────────────────────────────────────────
# Token du bot (Discord Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=

# ID du serveur Discord ATFR (clic droit sur le serveur → Copier l'ID)
DISCORD_GUILD_ID=

# ── Netlify (site ATFR) ───────────────────────────────────────────────────────
# URL de base du site Netlify (sans slash final)
SITE_URL=https://atfrv2.netlify.app

# Secret partagé avec Netlify (même valeur que DISCORD_SYNC_SECRET dans Netlify)
# Générer avec : openssl rand -hex 32
DISCORD_SYNC_SECRET=

# ── Comportement ─────────────────────────────────────────────────────────────
# Cron de sync membres complète (défaut : tous les jours à 03:00)
SYNC_CRON=0 3 * * *

# Activer les logs détaillés (true/false)
DEBUG=false

# Port du tableau de bord local (statut, vocal en direct, logs)
DASHBOARD_PORT=3000
