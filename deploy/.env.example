# ============================================================================
#  Configuration de la stack auto-hébergée ATFR (deploy/.env)
#  Copie ce fichier en `deploy/.env` et remplis les valeurs.
#  La plupart se retrouvent dans Netlify -> Site settings -> Environment.
# ============================================================================

# --- Domaine servi par Caddy (HTTPS auto). Ex : atfr-wot.com --------------
SITE_DOMAIN=exemple.com

# --- Installation native (Windows/Linux, hors Docker) : optionnel ----------
# Chemin de caddy.exe si pas dans le PATH (ex : C:\caddy\caddy.exe).
# CADDY_BIN=
# Upstream de l'API (défaut localhost:8080).
# API_UPSTREAM=localhost:8080

# --- Supabase (garde le projet cloud existant, free tier) -----------------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # SECRET — ne jamais exposer côté client

# --- Wargaming / tomato.gg ------------------------------------------------
WOT_APPLICATION_ID=xxxxxxxx
CLAN_ID=500197997
TOMATO_API_KEY=xxxxxxxx

# --- Cloudinary (images) --------------------------------------------------
CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx                 # SECRET

# --- Discord (fonctions + bot) --------------------------------------------
DISCORD_BOT_TOKEN=xxxx                      # SECRET
DISCORD_GUILD_ID=xxxxxxxxxxxxxxxxxx
DISCORD_SYNC_SECRET=xxxx                    # SECRET partagé avec le bot
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_RH_ALERTS_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Monitoring (tâche monitor-heartbeat, toutes les 5 min) ----------------
# Alerte Discord quand Supabase devient injoignable / se rétablit.
# Repli sur DISCORD_RH_ALERTS_WEBHOOK_URL si non défini.
# DISCORD_MONITOR_WEBHOOK_URL=https://discord.com/api/webhooks/...
# URL de ping « dead-man » (Healthchecks.io, gratuit) : couvre la panne TOTALE
# du VPS/API (si les pings s'arrêtent, Healthchecks.io t'alerte sur Discord).
# MONITOR_HEARTBEAT_URL=https://hc-ping.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Cible du test « le site répond-il ? » — défaut http://localhost (Caddy en
# local). Mets l'URL HTTPS publique pour un test plus profond si tu veux.
# MONITOR_SITE_URL=http://localhost

# --- Sauvegardes base de données (deploy/backup-db.mjs) --------------------
# Chaîne de connexion Postgres — prends la « Session pooler » dans Supabase
# (Settings → Database → Connection string → Session pooler). SECRET.
# SUPABASE_DB_URL=postgresql://postgres.xxxx:MOT_DE_PASSE@aws-0-eu-west-3.pooler.supabase.com:5432/postgres
# Nombre de dumps conservés (rotation). Défaut : 14.
# BACKUP_RETENTION=14
# Dossier de sortie (défaut : <repo>/backups).
# BACKUP_DIR=C:\atfr-backups
# Chemin de pg_dump.exe si pas dans le PATH.
# PG_DUMP_BIN=C:\Program Files\PostgreSQL\17\bin\pg_dump.exe

# --- CORS : origines autorisées à appeler les fonctions Discord -----------
# Mets ton domaine (et l'URL du bot si besoin), séparés par des virgules.
ALLOWED_ORIGINS=https://exemple.com

# --- Valeurs VITE_ côté serveur (certaines fonctions les lisent en repli) --
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_CLAN_ID=500197997
VITE_WOT_APPLICATION_ID=xxxxxxxx
VITE_CLOUDINARY_CLOUD_NAME=xxxx

# ============================================================================
#  Variables « bakées » dans le front au build (Dockerfile.web).
#  Elles doivent aussi être présentes ici car docker-compose les passe en
#  build args au service `web`.
# ============================================================================
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_CLAN_TAG=ATFR
VITE_SITE_URL=https://exemple.com
