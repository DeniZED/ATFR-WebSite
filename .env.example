# -----------------------------------------------------------------------------
# Variables CLIENT (préfixe VITE_, embarquées dans le bundle — pas de secrets)
# -----------------------------------------------------------------------------

# Supabase (database + auth)
# Project Settings → API. L'anon key est publique ; ne mettez JAMAIS la
# service_role key ici.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudinary — cloud name public (non secret)
VITE_CLOUDINARY_CLOUD_NAME=dk1fqwz2s
# VITE_CLOUDINARY_UPLOAD_PRESET est obsolète depuis le passage aux uploads signés.

# World of Tanks API (côté client pour la recherche de pseudo)
VITE_WOT_APPLICATION_ID=your-wot-application-id

# Clan
VITE_CLAN_ID=500191501
VITE_CLAN_TAG=ATFR

# Site
VITE_SITE_URL=https://atfr-clan.netlify.app

# -----------------------------------------------------------------------------
# Variables SERVEUR (Netlify Functions — secrets, SANS préfixe VITE_)
# À configurer uniquement dans Netlify → Site settings → Environment variables.
# N'apparaissent JAMAIS dans le bundle client.
# -----------------------------------------------------------------------------

# Webhook Discord (utilisé par netlify/functions/discord-notify)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# WoT API côté serveur (utilisée par player-stats / clan-stats).
# Si absente, retombe sur VITE_WOT_APPLICATION_ID.
# WOT_APPLICATION_ID=your-wot-application-id

# ID du clan par défaut côté serveur.
# CLAN_ID=500191501

# Liste d'origines autorisées à appeler les Netlify Functions (CSV).
# OBLIGATOIRE en production — si absent, toutes les requêtes cross-origin sont rejetées.
# En développement local, ajouter http://localhost:5173
# ALLOWED_ORIGINS=https://atfr-clan.fr,https://atfrv2.netlify.app

# SECRET — clé de signature des player tokens (HMAC-SHA256).
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si absent, retombe sur SUPABASE_SERVICE_ROLE_KEY (déconseillé — utilisez une clé dédiée).
# PLAYER_TOKEN_SECRET=your-32-bytes-random-hex

# Supabase cote serveur pour les fonctions RH Discord.
# SUPABASE_URL et SUPABASE_ANON_KEY sont optionnelles si VITE_SUPABASE_URL
# et VITE_SUPABASE_ANON_KEY existent deja dans Netlify.
# SECRET — ne jamais exposer côté client ni committer dans le dépôt.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SECRET — Cloudinary API (utilisé par cloudinary-sign et cloudinary-delete).
# Obtenir sur console.cloudinary.com → Settings → API Keys.
# CLOUDINARY_CLOUD_NAME=dk1fqwz2s
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Bot Discord pour synchroniser tous les membres et enregistrer les vocaux.
# Activer le privileged intent "Server Members Intent" dans le portail Discord.
# DISCORD_BOT_TOKEN=your-discord-bot-token
# Optionnel si le contenu admin `discord_server_id` est renseigne.
# DISCORD_GUILD_ID=your-discord-server-id
# DISCORD_SYNC_SECRET=long-random-secret-shared-with-the-bot

# Webhook Discord pour le rapport RH hebdomadaire automatique
# (netlify/functions/rh-weekly-digest — chaque lundi 08:00 UTC).
# Crée un webhook sur le salon staff : Paramètres du salon → Intégrations → Webhooks.
# DISCORD_RH_ALERTS_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
