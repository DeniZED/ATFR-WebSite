# --- Supabase (database + auth) ---
# Créez un projet sur https://supabase.com puis récupérez ces valeurs dans
# Project Settings -> API. L'anon key est publique, ne mettez JAMAIS la
# service_role key ici.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- World of Tanks API ---
# Créez une application sur https://developers.wargaming.net/
# et collez l'application_id ici.
VITE_WOT_APPLICATION_ID=your-wot-application-id

# --- Clan ---
VITE_CLAN_ID=500191501
VITE_CLAN_TAG=ATFR

# --- Discord webhook ---
# Idéalement, déplacez cet envoi côté serveur (Supabase Edge Function).
# En l'absence, garder côté client est fonctionnel mais le webhook est visible
# dans le bundle.
VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# --- Site ---
VITE_SITE_URL=https://atfr-clan.netlify.app
