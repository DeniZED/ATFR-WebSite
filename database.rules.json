{
  "rules": {
    ".read": false,
    ".write": false,
    "applications": {
      ".read": "auth != null",
      ".write": true,
      "$applicationId": {
        ".validate": "newData.hasChildren(['playerName', 'timestamp', 'status'])",
        "timestamp": {
          ".validate": "newData.isNumber() && newData.val() <= now"
        },
        "status": {
          ".validate": "newData.val() === 'pending' || newData.val() === 'accepted' || newData.val() === 'rejected'"
        }
      }
    },
    "events": {
      ".read": true,
      ".write": "auth != null",
      "$eventId": {
        ".validate": "newData.hasChildren(['title', 'date', 'time', 'type', 'description', 'isPublic'])"
      }
    },
    "members": {
      ".read": true,
      ".write": "auth != null",
      "$memberId": {
        ".validate": "newData.hasChildren(['account_id', 'account_name', 'role'])"
      }
    },
    "activityLogs": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$logId": {
        ".validate": "newData.hasChildren(['timestamp', 'type', 'account_id'])"
      }
    }
  }
}